;   param=value ; assign values to parameters

config_version=5

[ambientcg]

extract_path="res://AmbientCG/Downloads"
material_file_directory="res://AmbientCG/Materials"
environment_file_directory="res://AmbientCG/Environments"

[application]

config/name="SubDTest"
run/main_scene="uid://ylpc2h0uxb5q"
config/features=PackedStringArray("4.5", "C#", "GL Compatibility")
config/icon="res://icon.svg"

[dotnet]

project/assembly_name="SubDTest"

[editor_plugins]

enabled=PackedStringArray("res://addons/ambientcg/plugin.cfg")

